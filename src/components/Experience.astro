---
interface TimelineItem {
  date: string;
  role: string;
  company: string;
  type: 'work' | 'project';
  description: string;
  tags: string[];
}

const timeline: TimelineItem[] = [
  {
    date: '2025年5月 至今',
    role: '主策划 & 技术策划',
    company: '上海月之底网络科技有限公司',
    type: 'work',
    description:
      '主导并落地多项核心玩法与系统设计，参与商业化、留存与数据驱动决策体系搭建，并直接使用 Roblox Studio + Lua 参与系统、战斗与 UI 实现。',
    tags: ['Roblox', 'Lua', 'UGC', '数据驱动'],
  },
  {
    date: '2024年6月 至 2025年5月',
    role: '主程序 & 技术策划',
    company: '上海月之底网络科技有限公司',
    type: 'work',
    description:
      '使用网易 Y3 编辑器 + Lua 独立搭建 RPG 项目完整系统，负责底层架构、核心系统、界面交互逻辑，并持续优化战斗体验与系统稳定性。',
    tags: ['Y3', 'Lua', 'RPG', '系统开发'],
  },
  {
    date: '2023年7月 至 2024年6月',
    role: '技术策划',
    company: 'Genies',
    type: 'work',
    description:
      '负责 Genies 元宇宙平台多款示例模板游戏的设计与开发，涵盖 Roguelike、放置、跑酷等类型，并实现 AI 系统与自研策划工具链。',
    tags: ['Unity', 'C#', 'Lua', 'AI'],
  },
  {
    date: '2023年7月 至 2024年6月',
    role: 'Unity 讲师',
    company: 'Concord Education',
    type: 'work',
    description:
      '负责线上与线下 Unity 游戏开发教学，设计课程内容并通过收集和分析反馈持续优化未来教学安排。',
    tags: ['Unity', '教学', '课程设计', '指导'],
  },
];
---

<section id="experience" class="py-28 px-6 relative overflow-hidden">
  <div class="absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-bg-surface to-transparent pointer-events-none" aria-hidden="true"></div>
  <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-bg-surface to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-5xl">
    <p class="font-mono text-xs text-neon-pink tracking-[0.3em] uppercase mb-3">// 第三部分</p>
    <h2 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">工作经历</h2>
    <div class="w-16 h-0.5 bg-neon-cyan mb-16"></div>

    <div class="relative timeline-container">
      <div
        class="absolute left-[17px] lg:left-1/2 top-0 bottom-0 w-px lg:-translate-x-1/2"
        style="background: linear-gradient(to bottom, transparent 0%, rgba(0,255,209,0.25) 15%, rgba(0,255,209,0.25) 85%, transparent 100%)"
        aria-hidden="true"
      ></div>

      {timeline.map((item, i) => {
        const isLeft = i % 2 === 0;
        const nodeColor = item.type === 'project' ? '#FF2E97' : '#00FFD1';

        return (
          <div
            class:list={[
              'timeline-item relative pl-10 lg:pl-0 mb-14 lg:mb-20',
              isLeft ? 'from-left' : 'from-right',
            ]}
            style={`transition-delay: ${i * 110}ms`}
          >
            <div
              class="absolute left-[17px] lg:left-1/2 top-[6px] w-[14px] h-[14px] rounded-full border-2 border-bg-dark -translate-x-1/2 z-10"
              style={`background:${nodeColor}; box-shadow: 0 0 10px ${nodeColor}99, 0 0 20px ${nodeColor}44`}
              aria-hidden="true"
            ></div>

            <div class:list={['lg:w-[46%]', isLeft ? 'lg:mr-auto lg:pr-12' : 'lg:ml-auto lg:pl-12']}>
              <div
                class="group relative bg-bg-surface border border-white/5 rounded-xl p-5 transition-all duration-300 hover:border-white/12"
                style="box-shadow: 0 2px 16px rgba(0,0,0,0.3)"
              >
                <div
                  class="absolute inset-x-0 top-0 h-px rounded-t-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                  style={`background: linear-gradient(90deg, transparent, ${nodeColor}80, transparent)`}
                ></div>

                <div class="flex flex-wrap items-center gap-2 mb-2.5">
                  <span
                    class="font-mono text-[10px] font-bold px-1.5 py-0.5 rounded uppercase tracking-wider"
                    style={`color:${nodeColor}; background:${nodeColor}18; border:1px solid ${nodeColor}30`}
                  >
                    工作
                  </span>
                  <span class="font-mono text-[11px] text-gray-500">{item.date}</span>
                </div>

                <h3 class="font-display text-base md:text-lg font-bold text-white mb-0.5 leading-snug">
                  {item.role}
                </h3>
                <p class="font-mono text-xs mb-3" style={`color:${nodeColor}88`}>{item.company}</p>

                <p class="text-gray-400 text-sm leading-relaxed mb-4">{item.description}</p>

                <div class="flex flex-wrap gap-1.5">
                  {item.tags.map((tag) => (
                    <span class="font-mono text-[10px] text-gray-600 px-1.5 py-0.5 bg-white/3 rounded border border-white/5">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .timeline-item {
    opacity: 0;
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .timeline-item.from-left  { transform: translateX(-28px); }
  .timeline-item.from-right { transform: translateX(28px); }

  @media (max-width: 1023px) {
    .timeline-item.from-right { transform: translateX(-28px); }
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<script>
  function initTimelineReveal() {
    const timelineItems = Array.from(document.querySelectorAll('.timeline-item'));
    if (timelineItems.length === 0) return;

    const revealIfNeeded = (el) => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.9) {
        el.classList.add('visible');
        return true;
      }
      return false;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 },
    );

    timelineItems.forEach((el) => {
      if (!revealIfNeeded(el)) {
        observer.observe(el);
      }
    });
  }

  document.addEventListener('astro:page-load', initTimelineReveal);
  initTimelineReveal();
</script>
