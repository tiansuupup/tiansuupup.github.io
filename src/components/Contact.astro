---
const socialLinks = [
  {
    label: '领英',
    href: 'https://www.linkedin.com/in/tiansu-li-bbb2721b7/',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: '邮箱',
    href: 'mailto:li.tians@northeastern.edu',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: '简历 PDF',
    href: '/resume/Tiansu_Li_CV.pdf',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg>`,
  },
];
---

<section id="contact" class="relative py-28 px-6 overflow-hidden bg-bg-surface">
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="orb orb-cyan"></div>
    <div class="orb orb-pink"></div>
  </div>

  <div
    class="absolute inset-0 pointer-events-none opacity-[0.025]"
    style="background-image: linear-gradient(#00FFD1 1px,transparent 1px),linear-gradient(90deg,#00FFD1 1px,transparent 1px); background-size:64px 64px"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-4xl text-center">
    <div data-animate="fade-up">
      <p class="font-mono text-xs text-neon-pink tracking-[0.3em] uppercase mb-3">// 第四部分</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mb-6">联系方式</h2>
      <div class="w-16 h-0.5 bg-neon-cyan mx-auto mb-10"></div>
    </div>

    <div data-animate="fade-up" style="transition-delay: 0.1s">
      <p class="text-gray-400 max-w-lg mx-auto text-base md:text-lg leading-relaxed mb-4">
        如果你正在寻找一位有一定 玩法策划、技术策划、UGC策划、独立开发 经验，且擅长使用AI优化工作流，同时能够快速搭建原型落地项目的 开发者/设计师，欢迎随时联系我。
      </p>
      <p class="text-gray-600 font-mono text-sm mb-12">
        欢迎联系。无论是游戏项目合作、产品交流，还是想聊聊玩法设计与技术实现，我都很乐意沟通。
      </p>
    </div>

    <div data-animate="fade-scale" style="transition-delay: 0.18s">
      <a
        href="mailto:li.tians@northeastern.edu"
        class="contact-cta group inline-flex items-center gap-3 font-mono text-sm px-10 py-4 rounded-lg border border-neon-cyan text-neon-cyan transition-all duration-300 mb-16"
      >
        <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-300 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        li.tians@northeastern.edu
      </a>
    </div>

    <div class="flex items-center gap-4 max-w-xs mx-auto mb-10" role="presentation">
      <div class="flex-1 h-px bg-white/5"></div>
      <span class="font-mono text-[10px] text-gray-700 tracking-widest">更多联系方式</span>
      <div class="flex-1 h-px bg-white/5"></div>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 text-left max-w-2xl mx-auto mb-10" data-animate="fade-up" style="transition-delay: 0.22s">
      <div class="rounded-lg border border-white/5 bg-bg-dark/40 px-4 py-3">
        <p class="font-mono text-[10px] text-gray-600 uppercase tracking-widest mb-1">地点</p>
        <p class="text-sm text-gray-300">深圳市</p>
      </div>
      <div class="rounded-lg border border-white/5 bg-bg-dark/40 px-4 py-3">
        <p class="font-mono text-[10px] text-gray-600 uppercase tracking-widest mb-1">手机号码</p>
        <p class="text-sm text-gray-300">+86 18612347269</p>
      </div>
      <div class="rounded-lg border border-white/5 bg-bg-dark/40 px-4 py-3">
        <p class="font-mono text-[10px] text-gray-600 uppercase tracking-widest mb-1">微信号码</p>
        <p class="text-sm text-gray-300">tiansuupup</p>
      </div>
      <div class="rounded-lg border border-white/5 bg-bg-dark/40 px-4 py-3">
        <p class="font-mono text-[10px] text-gray-600 uppercase tracking-widest mb-1">毕业院校</p>
        <p class="text-sm text-gray-300">美国东北大学 / 新泽西州立罗格斯大学</p>
      </div>
    </div>

    <div class="flex flex-wrap justify-center gap-4" data-animate="fade-up" style="transition-delay: 0.26s">
      {socialLinks.map(({ label, href, icon }) => (
        <a
          href={href}
          target={href.startsWith('http') ? '_blank' : undefined}
          rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
          aria-label={label}
          class="social-link group flex items-center gap-2.5 px-5 py-2.5 rounded-lg border border-white/5 bg-bg-dark/50 text-gray-500 transition-all duration-300 hover:bg-bg-dark hover:scale-105"
        >
          <span class="w-4 h-4 flex-shrink-0 transition-colors duration-300" set:html={icon} />
          <span class="font-mono text-xs transition-colors duration-300">{label}</span>
        </a>
      ))}
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mt-12" data-animate="fade-up" style="transition-delay: 0.32s">
      {[
        '/images/moments/i-love-players.webp',
        '/images/moments/game-jam-2.webp',
        '/images/moments/game-jam-1.webp',
        '/images/moments/game-jam-3.webp',
        '/images/moments/game-jam-4.webp',
      ].map((src, index) => (
        <div class:list={['overflow-hidden rounded-lg border border-white/5 bg-bg-dark/40', index === 0 ? 'col-span-2 sm:col-span-1' : '']}>
          <img src={src} alt="" class="w-full h-24 object-cover opacity-85 hover:opacity-100 transition-opacity duration-300" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    animation: orb-float 12s ease-in-out infinite;
    will-change: transform;
  }
  .orb-cyan {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0, 255, 209, 0.12) 0%, transparent 70%);
    top: -100px;
    left: -100px;
    animation-delay: 0s;
  }
  .orb-pink {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 46, 151, 0.1) 0%, transparent 70%);
    bottom: -80px;
    right: -80px;
    animation-delay: -6s;
  }
  @keyframes orb-float {
    0%, 100% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.05); }
    66% { transform: translate(-15px, 18px) scale(0.97); }
  }

  .contact-cta:hover {
    background-color: rgba(0, 255, 209, 0.08);
    box-shadow: 0 0 20px rgba(0, 255, 209, 0.3), 0 0 60px rgba(0, 255, 209, 0.1);
  }

  .social-link:hover {
    border-color: rgba(255, 255, 255, 0.12);
    color: #e5e7eb;
  }
</style>
