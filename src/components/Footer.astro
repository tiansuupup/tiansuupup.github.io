---
const socialLinks = [
  {
    label: '领英',
    href: 'https://www.linkedin.com/in/tiansu-li-bbb2721b7/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: '邮箱',
    href: 'mailto:li.tians@northeastern.edu',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: '简历',
    href: '/resume/Tiansu_Li_CV.pdf',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg>`,
  },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-bg-surface mt-0">
  <div class="mx-auto max-w-6xl px-6 py-10 flex flex-col items-center gap-6">
    <div class="flex items-center gap-6">
      {socialLinks.map(({ label, href, icon }) => (
        <a
          href={href}
          target={href.startsWith('http') ? '_blank' : undefined}
          rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
          aria-label={label}
          class="text-gray-500 hover:text-neon-cyan transition-colors duration-200 hover:drop-shadow-[0_0_8px_#00FFD1]"
          set:html={icon}
        />
      ))}
    </div>

    <div class="w-24 h-px bg-gradient-to-r from-transparent via-neon-cyan/40 to-transparent"></div>

    <p class="font-mono text-xs text-gray-600 text-center">
      <span class="text-neon-pink">&lt;</span>
      使用 Astro + React 构建
      <span class="text-neon-pink">/&gt;</span>
      &nbsp;&mdash;&nbsp;
      &copy; {year} 李天粟。保留所有权利。
    </p>
  </div>
</footer>
