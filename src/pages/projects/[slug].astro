---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projectBannerMap, projectMediaMap } from '../../data/projectMedia';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, tags, date, github, demo } = entry.data;
const mediaItems = projectMediaMap[entry.id] ?? [];
const bannerImage = projectBannerMap[entry.id] ?? entry.data.cover;

const primaryTag = tags[0]?.toLowerCase() ?? '';
const accentColor = primaryTag.includes('unity') ? '#00FFD1'
  : primaryTag.includes('unreal') ? '#FF2E97'
  : primaryTag.includes('roblox') ? '#FFD700'
  : primaryTag.includes('web') || primaryTag.includes('three') ? '#FFD700'
  : '#00FFD1';

const formattedDate = (() => {
  const [year, month] = date.split('-');
  return month ? `${year}.${month}` : year;
})();

function translateTag(tag: string) {
  const normalized = tag.toLowerCase();
  const tagMap: Record<string, string> = {
    design: '策划',
    'live ops': '长线运营',
    mobile: '移动端',
    'game ai': '游戏 AI',
    'behavior tree': '行为树',
    fsm: '状态机',
    'data visualization': '数据可视化',
    research: '研究',
    'serious game': '严肃游戏',
    narrative: '叙事',
    ui: '界面设计',
    accessibility: '无障碍',
    racing: '竞速',
    ai: '人工智能',
    stealth: '潜行',
    tps: '第三人称射击',
    demo: '演示',
    adventure: '冒险',
    puzzle: '解谜',
    award: '获奖作品',
    horror: '恐怖',
    'rogue-lite': '肉鸽',
    'ar/vr': 'AR/VR',
    ar: '增强现实',
    vr: '虚拟现实',
    'card game': '纸牌',
    moba: 'MOBA',
    solo: '独立开发',
    casual: '休闲',
    platformer: '平台动作',
  };

  return tagMap[normalized] ?? tag;
}
---

<BaseLayout title={`${title} | 李天粟作品集`} description={description}>
  <div class="pt-28 pb-12 px-6 border-b border-white/5">
    <div class="mx-auto max-w-3xl">
      <a
        href="/#projects"
        class="inline-flex items-center gap-2 font-mono text-xs text-gray-500 hover:text-neon-cyan transition-colors duration-200 mb-8"
      >
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        返回作品列表
      </a>

      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => (
          <span
            class="font-mono text-xs px-2 py-0.5 rounded"
            style={`color:${accentColor}; background:${accentColor}18; border:1px solid ${accentColor}30`}
          >
            {translateTag(tag)}
          </span>
        ))}
        <span class="font-mono text-xs text-gray-600 px-2 py-0.5">{formattedDate}</span>
      </div>

      <h1 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
        {title}
      </h1>
      <p class="text-gray-400 text-lg leading-relaxed max-w-xl">{description}</p>

      {github && (
        <div class="flex gap-4 mt-6">
          {github && (
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-mono text-sm px-5 py-2.5 border rounded transition-all duration-200 hover:bg-white/5"
              style={`border-color:${accentColor}50; color:${accentColor}`}
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              查看 GitHub
            </a>
          )}
          {/* {demo && (
            <a
              href={demo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-mono text-sm px-5 py-2.5 rounded text-bg-dark transition-all duration-200"
              style={`background:${accentColor}; box-shadow: 0 0 16px ${accentColor}44`}
            >
              查看项目
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          )} */}
        </div>
      )}
    </div>
  </div>

  <div
    class="w-[44%] max-w-3xl mx-auto aspect-[5/3] relative overflow-hidden rounded-xl"
    style={`background: linear-gradient(135deg, #0a0a0f 0%, ${accentColor}18 100%)`}
    aria-hidden="true"
  >
    {bannerImage ? (
      <>
        <img src={bannerImage} alt="" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black/45"></div>
      </>
    ) : null}
    <div class="absolute inset-x-0 top-0 h-20 md:h-28 bg-gradient-to-b from-bg-dark via-bg-dark/80 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-20 md:h-28 bg-gradient-to-t from-bg-dark via-bg-dark/80 to-transparent"></div>
    <div
      class="absolute inset-0 opacity-[0.05]"
      style={`background-image: linear-gradient(${accentColor} 1px,transparent 1px),linear-gradient(90deg,${accentColor} 1px,transparent 1px); background-size:40px 40px`}
    ></div>
    <div class="absolute bottom-0 left-0 right-0 h-px" style={`background: linear-gradient(90deg, transparent, ${accentColor}60, transparent)`}></div>
  </div>

  <article class="mx-auto max-w-3xl px-6 py-16 prose-custom">
    <div class="prose-article">
      <Content />
    </div>
  </article>

  {mediaItems.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 pb-20">
      <div class="mb-8">
        <p class="font-mono text-xs text-neon-pink tracking-[0.3em] uppercase mb-3">// 相关内容</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white">项目媒体</h2>
        <div class="w-16 h-0.5 bg-neon-cyan mt-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
        {mediaItems.map((item) => (
          <div class="rounded-xl overflow-hidden border border-white/8 bg-bg-surface/70" style="box-shadow: 0 8px 30px rgba(0,0,0,0.3)">
            {item.type === 'embed' ? (
              <div class="aspect-video bg-black">
                <iframe
                  src={item.src}
                  class="w-full h-full"
                  loading="lazy"
                  allowfullscreen
                  referrerpolicy="strict-origin-when-cross-origin"
                  title={`${title} 视频演示`}
                ></iframe>
              </div>
            ) : (
              <img
                src={item.src}
                alt={`${title} 项目截图`}
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  <div class="mx-auto max-w-3xl px-6 pb-20">
    <a
      href="/#projects"
      class="inline-flex items-center gap-2 font-mono text-sm border px-6 py-3 rounded transition-colors duration-200 text-gray-400 hover:text-neon-cyan hover:border-neon-cyan/40"
      style="border-color: rgba(255,255,255,0.08)"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      返回全部项目
    </a>
  </div>
</BaseLayout>

<style>
  .prose-article :global(h2) {
    font-family: "Space Mono", monospace;
    color: white;
    font-size: 1.4rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .prose-article :global(h3) {
    font-family: "Space Mono", monospace;
    color: #e5e7eb;
    font-size: 1.1rem;
    font-weight: 700;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }
  .prose-article :global(p) {
    color: #9ca3af;
    line-height: 1.8;
    margin-bottom: 1.2rem;
    font-size: 0.975rem;
  }
  .prose-article :global(ul),
  .prose-article :global(ol) {
    color: #9ca3af;
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
  }
  .prose-article :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.7;
    font-size: 0.975rem;
  }
  .prose-article :global(li::marker) {
    color: #00FFD1;
  }
  .prose-article :global(strong) {
    color: #e5e7eb;
    font-weight: 600;
  }
  .prose-article :global(code) {
    font-family: "JetBrains Mono", monospace;
    background: rgba(0, 255, 209, 0.06);
    color: #00FFD1;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    border: 1px solid rgba(0, 255, 209, 0.15);
  }
</style>
