---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Hero } from '../components/Hero';
import About from '../components/About.astro';
import { Projects } from '../components/Projects';
import type { ProjectItem } from '../components/Projects';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
import { getCollection } from 'astro:content';

const rawProjects = await getCollection('projects');

// Sort by date descending (newest first), then serialize for React island
const projectsData: ProjectItem[] = rawProjects
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .map((p) => ({
    id:          p.id,
    title:       p.data.title,
    description: p.data.description,
    tags:        p.data.tags,
    cover:       p.data.cover,
    date:        p.data.date,
    github:      p.data.github,
    demo:        p.data.demo,
    featured:    p.data.featured,
  }));
---

<BaseLayout
  title="Portfolio | Game Developer"
  description="Personal portfolio of a game developer — showcasing games, creative code, and interactive experiences."
>
  <!-- ──────────────────────────────────────────────────────────────────────
       Section 1: Hero — React island (particles + glitch + typewriter)
       ──────────────────────────────────────────────────────────────────── -->
  <Hero client:load />

  <!-- ──────────────────────────────────────────────────────────────────────
       Section 2: About — Astro shell + SkillTree React island
       ──────────────────────────────────────────────────────────────────── -->
  <About />

  <!-- ──────────────────────────────────────────────────────────────────────
       Section 3: Projects — React island (filter + cards)
       ──────────────────────────────────────────────────────────────────── -->
  <section id="projects" class="py-28 px-6 bg-bg-surface relative overflow-hidden">
    <!-- Faint radial glow -->
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] pointer-events-none"
      style="background: radial-gradient(ellipse at center, rgba(255,46,151,0.05) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-6xl">
      <p class="font-mono text-xs text-neon-pink tracking-[0.3em] uppercase mb-3">// Section 02</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">Projects</h2>
      <div class="w-16 h-0.5 bg-neon-cyan mb-14"></div>

      <!-- Projects React island: filter bar + animated card grid -->
      <Projects client:visible projects={projectsData} />
    </div>
  </section>

  <!-- ──────────────────────────────────────────────────────────────────────
       Section 4: Experience — alternating timeline
       ──────────────────────────────────────────────────────────────────── -->
  <Experience />

  <!-- ──────────────────────────────────────────────────────────────────────
       Section 5: Contact
       ──────────────────────────────────────────────────────────────────── -->
  <Contact />
</BaseLayout>
